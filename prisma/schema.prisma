generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MEMBER
}

enum InventoryStatus {
  AVAILABLE
  BORROWED
  MAINTENANCE
}

enum BorrowingStatus {
  ACTIVE
  RETURNED
  OVERDUE
}

enum ReservationStatus {
  PENDING
  FULFILLED
  CANCELLED
}

enum FineStatus {
  UNPAID
  PAID
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  role      Role     @default(MEMBER)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  borrowings   Borrowing[]
  reservations Reservation[]

  @@map("users")
}

model Book {
  id         Int      @id @default(autoincrement())
  title      String
  author     String
  isbn       String   @unique
  summary    String?
  categoryId Int      @map("category_id")
  createdAt  DateTime @default(now()) @map("created_at")

  category       Category        @relation(fields: [categoryId], references: [id])
  inventoryItems InventoryItem[]
  reservations   Reservation[]

  @@index([title])
  @@index([author])
  @@index([isbn])
  @@map("books")
}

model Category {
  id    Int    @id @default(autoincrement())
  name  String @unique
  books Book[]

  @@map("categories")
}

model InventoryItem {
  id        Int             @id @default(autoincrement())
  bookId    Int             @map("book_id")
  barcode   String          @unique
  status    InventoryStatus @default(AVAILABLE)
  condition String?

  book       Book        @relation(fields: [bookId], references: [id])
  borrowings Borrowing[]

  @@map("inventory_items")
}

model Borrowing {
  id              Int             @id @default(autoincrement())
  userId          Int             @map("user_id")
  inventoryItemId Int             @map("inventory_item_id")
  borrowedAt      DateTime        @default(now()) @map("borrowed_at")
  dueDate         DateTime        @map("due_date")
  returnedAt      DateTime?       @map("returned_at")
  status          BorrowingStatus @default(ACTIVE)

  user          User          @relation(fields: [userId], references: [id])
  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id])
  fines         Fine[]

  @@map("borrowings")
}

model Reservation {
  id         Int               @id @default(autoincrement())
  userId     Int               @map("user_id")
  bookId     Int               @map("book_id")
  reservedAt DateTime          @default(now()) @map("reserved_at")
  status     ReservationStatus @default(PENDING)

  user User @relation(fields: [userId], references: [id])
  book Book @relation(fields: [bookId], references: [id])

  @@map("reservations")
}

model Fine {
  id          Int        @id @default(autoincrement())
  borrowingId Int        @map("borrowing_id")
  amount      Float
  status      FineStatus @default(UNPAID)
  createdAt   DateTime   @default(now()) @map("created_at")

  borrowing Borrowing @relation(fields: [borrowingId], references: [id])

  @@map("fines")
}
